# ============================================================
# ContentAI Studio — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Base de données ---
DATABASE_URL=postgresql://contentai:contentai_secret@localhost:5433/contentai_db

# --- PostgreSQL (docker-compose local) ---
POSTGRES_USER=contentai
POSTGRES_PASSWORD=contentai_secret
POSTGRES_DB=contentai_db

# --- Redis (optionnel en dev, requis en prod pour les sessions) ---
REDIS_URL=redis://localhost:6379

# --- Auth.js ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET=changeme-at-least-32-characters-long-secret
AUTH_URL=http://localhost:3000

# --- Notion OAuth ---
# Créer une intégration sur https://www.notion.so/my-integrations
AUTH_NOTION_ID=your-notion-oauth-client-id
AUTH_NOTION_SECRET=your-notion-oauth-client-secret

# --- Email (Resend) ---
# Créer un compte sur https://resend.com
AUTH_RESEND_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# --- Anthropic ---
# Clé API sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key
ANTHROPIC_MODEL=claude-opus-4-6

# --- Stripe (optionnel) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
