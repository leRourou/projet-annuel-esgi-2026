{
  "name": "contentai-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "docker compose --profile tools run --rm migrate npx tsx ./node_modules/typeorm/cli.js migration:run -d src/shared/infrastructure/database/data-source.ts",
    "db:generate": "docker compose --profile tools run --rm migrate npx tsx ./node_modules/typeorm/cli.js migration:generate -d src/shared/infrastructure/database/data-source.ts",
    "db:revert": "docker compose --profile tools run --rm migrate npx tsx ./node_modules/typeorm/cli.js migration:revert -d src/shared/infrastructure/database/data-source.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@auth/core": "^0.37.4",
    "@auth/typeorm-adapter": "^2.7.4",
    "@notionhq/client": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.4",
    "@tailwindcss/postcss": "^4.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "next": "15.2.4",
    "next-auth": "5.0.0-beta.25",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "^3.13.0",
    "stripe": "^17.5.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.15",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.8"
  }
}